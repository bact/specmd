{% extends "entity.tex.j2" %}
{% block metadata %}
\begin{tabular}{ | l l | } 
\hline
 \emph{Name:} & {{metadata["name"]}} \\
\hline
\end{tabular}
{% endblock %}
%
{% block extra %}
\spdxpagepart{Entries}
\begin{description}
{% for name, val in entries | dictsort %}
\item[ {{-tex_escape(name)-}} ]
    {{-markdown_to_tex(val["description"])-}}{% if val["from"] != ["Element"] or val["to"] != ["Element"] or val["relationshipClass"] != "Relationship" %} (from: {{val["from"] | join(", ")}}, to: {{val["to"] | join(", ")}}, relationshipClass: {{tex_escape(val["relationshipClass"])}}){% endif %}
{% endfor %}
\end{description}
{% endblock %}
